# ─────────────────────────────────────────────────────────────
# FRD AI Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Azure DevOps ──────────────────────────────────────────────
# Your ADO organization URL, e.g. https://dev.azure.com/mycompany
ADO_ORG_URL=https://dev.azure.com/your-org

# The ADO project name containing the Work Items
ADO_PROJECT=your-project-name

# Personal Access Token — needs: Work Items (Read & Write), Attachments (Read & Write)
# Generate at: https://dev.azure.com/{org}/_usersSettings/tokens
ADO_PAT=your-ado-pat-token-here

GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-3-flash-preview

# ── HuggingFace ───────────────────────────────────────────────
# Free API token from https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here

# Model to use (free inference API). Options:
#   mistralai/Mistral-7B-Instruct-v0.3   (default, recommended)
#   HuggingFaceH4/zephyr-7b-beta
#   meta-llama/Llama-3.2-3B-Instruct     (requires HF Pro for some)
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Webhook Security (optional but recommended) ────────────────
# Set a secret and configure the same value in your ADO service hook
WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
OUTPUT_DIR=outputs
